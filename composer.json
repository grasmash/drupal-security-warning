{
  "name": "grasmash/drupal-security-warning",
  "description": "Warns users installing Drupal project versions not supported by Security Team.",
  "keywords": [ "drupal", "security" ],
  "authors": [
    {
      "name": "Matthew Grasmick"
    }
  ],
  "support": {
    "issues": "https://github.com/grasmash/drupal-security-warning/issues"
  },
  "type": "composer-plugin",
  "license": "GPL-2.0-or-later",
  "require": {
    "php": ">=8.1",
    "composer-plugin-api": "^2.0"
  },
  "require-dev": {
    "composer/composer": "^2.9.8",
    "squizlabs/php_codesniffer": "^3.13 || ^4.0",
    "phpunit/phpunit": "^10.5.62 || ^11.5.50 || ^12.4 || ^13.0",
    "symfony/filesystem": "^6.4 || ^7.0 || ^8.0",
    "symfony/process": "^6.4.33 || ^7.3.11 || ^8.0"
  },
  "autoload": {
    "psr-4": {
      "grasmash\\DrupalSecurityWarning\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "grasmash\\DrupalSecurityWarning\\Tests\\": "tests/phpunit/"
    }
  },
  "config": {
    "sort-packages": true
  },
  "extra": {
    "class": "grasmash\\DrupalSecurityWarning\\Composer\\Plugin",
    "branch-alias": {
      "dev-master": "2.x-dev"
    }
  },
  "scripts": {
    "cs": "phpcs -n --standard=PSR12 src",
    "cbf": "phpcbf -n --standard=PSR12 src",
    "unit": "phpunit",
    "lint": [
      "find src -name '*.php' -print0 | xargs -0 -n1 php -l",
      "find tests -name '*.php' -print0 | xargs -0 -n1 php -l"
    ],
    "test": [
      "@lint",
      "@unit",
      "@cs"
    ]
  }
}
